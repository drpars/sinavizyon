{
  "manifest_version": 3,
  "name": "SİNA VİZYON",
  "version": "1.5.6",
  "description": "SİNA ve HYP sistemlerinden performans verilerini çeker, katsayı hesaplar.",
  "author": "drpars",
  "permissions": ["storage"],
  "host_permissions": [
    "https://sina.saglik.gov.tr/*",
    "https://hyp.saglik.gov.tr/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "SİNA & HYP Yönetim",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "SİNA VİZYON",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sina.saglik.gov.tr/*",
        "https://hyp.saglik.gov.tr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sina-hyp-yonetim@drpars.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent",
          "healthInfo",
          "websiteActivity"
        ]
      }
    }
  }
}

