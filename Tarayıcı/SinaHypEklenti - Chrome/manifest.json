{
  "manifest_version": 3,
  "name": "SİNA VİZYON",
  "version": "2.1.0",
  "description": "SİNA ve HYP sistemleri için yan panel eklentisi",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": ["https://sina.saglik.gov.tr/*", "https://hyp.saglik.gov.tr/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Paneli Aç",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://sina.saglik.gov.tr/*", "https://hyp.saglik.gov.tr/*"],
      "js": ["content.js"],
      "all_frames": false,
      "run_at": "document_end"
    }
  ]
}
