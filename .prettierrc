{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "printWidth": 120,
  "endOfLine": "lf",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^[a-zA-Z]",
    "^@",
    "^[.]/",
    "^[.][.]/"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
