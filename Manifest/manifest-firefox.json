{
  "manifest_version": 3,
  "name": "SİNA VİZYON",
  "version": "2.1.3",
  "description": "SİNA ve HYP sistemlerinden performans verilerini çeker, katsayı hesaplar.",
  "author": "drpars",
  "permissions": ["storage"],
  "host_permissions": [
    "https://sina.saglik.gov.tr/*",
    "https://hyp.saglik.gov.tr/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "SİNA & HYP Yönetim",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "SİNA VİZYON",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "open_at_install": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sina.saglik.gov.tr/*",
        "https://hyp.saglik.gov.tr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sinahyp-yonetim@drpars.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
